### Create review task
POST http://localhost:8080/api/reviews
Content-Type: application/json

{
  "title": "Stage 4 E2E Evidence",
  "text": "The product launch plan says the team will launch in Q3. The plan has a clear milestone list but does not name risk owners. Marketing and engineering dependencies are mentioned without dates. The rollout needs a readiness checklist before public release.",
  "requirement": "Review structure, logic, and risk. Cite the document chunks when giving evidence.",
  "secondRoundEnabled": false
}

### Subscribe to review progress
GET http://localhost:8080/api/reviews/{{reviewTaskId}}/events
Accept: text/event-stream

### Get review task status
GET http://localhost:8080/api/reviews/{{reviewTaskId}}

### Expected completed response shape
# {
#   "status": "COMPLETED",
#   "report": {
#     "overallScore": 76,
#     "summary": "Synthesized 3 specialist reviews with an overall score of 76.",
#     "strengths": [],
#     "weaknesses": [],
#     "actions": [],
#     "finalMarkdown": "# Review Report\n\n..."
#   },
#   "specialistReviews": [
#     {
#       "role": "STRUCTURE",
#       "score": 78,
#       "feedback": "The document has a workable structure, but key conclusions should appear earlier.",
#       "suggestions": ["Move the main conclusion before detailed execution notes."],
#       "confidence": 0.7
